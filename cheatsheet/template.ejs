<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PicoCalc Cheatsheet</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <button id="dark-toggle" aria-label="Toggle theme">lite</button>

  <header>
    <h1>zerocalc</h1>
  </header>

  <main>
    <section class="panel keyboard-panel">
      <h2>keyboard shortcuts</h2>
      <div class="category-grid">
        <% for (const [category, items] of Object.entries(shortcutCategories)) { %>
        <div class="category-block">
          <h3><%= category.toLowerCase() %></h3>
          <div class="shortcut-list">
            <% items.forEach(function(item) { %>
            <div class="shortcut-row">
              <div class="key"><code><%- hlShortcut(item.shortcut) %></code></div>
              <div class="desc"><%= item.description %></div>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>
      </div>
    </section>

    <section class="panel pico8-kbd-panel">
      <h2>pico-8 keyboard shortcuts</h2>
      <div class="category-grid">
        <% for (const [category, items] of Object.entries(pico8ShortcutCategories)) { %>
        <div class="category-block">
          <h3><%= category.toLowerCase() %></h3>
          <div class="shortcut-list">
            <% items.forEach(function(item) { %>
            <div class="shortcut-row">
              <div class="key"><code><%- hlShortcut(item.shortcut) %></code></div>
              <div class="desc"><%= item.description %></div>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>
      </div>
    </section>

    <section class="panel terminal-panel">
      <h2>terminal</h2>
      <div class="category-grid">
        <% for (const [category, items] of Object.entries(terminalCategories)) { %>
        <div class="category-block">
          <h3><%= category.toLowerCase() %></h3>
          <% items.forEach(function(item) { %>
          <div class="api-entry">
            <code class="sig"><%- hlSig(item.signature) %></code>
            <span class="desc"><%= item.description %></span>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>
    </section>

    <section class="panel api-panel">
      <h2>pico-8 api</h2>
      <div class="category-grid">
        <% for (const [category, items] of Object.entries(apiCategories)) { %>
        <div class="category-block">
          <h3><%= category.replace('API: ', '').toLowerCase() %></h3>
          <% items.forEach(function(item) { %>
          <div class="api-entry">
            <code class="sig"><%- hlSig(item.signature) %></code>
            <span class="desc"><%= item.description %></span>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
